# ============================================================================
# Oracle Configuration for Base Localnet (Hardhat) — Local E2E Testing
# ============================================================================
# This file contains environment variables for running the oracle against a
# fresh Hardhat node with fully mocked AI and storage (no external dependencies).
#
# For live E2E testing:
# 1. Start Hardhat: npx hardhat node --network localnet
# 2. Deploy contracts: npm run deploy:base-localnet
# 3. Set the contract addresses in this file
# 4. Start the oracle: npm run start:base-localnet
#
# ============================================================================

# --- NETWORK SELECTION ---
# Must be 'base-localnet' to target the local Hardhat node on http://127.0.0.1:8545
NETWORK_NAME=base-localnet

# --- ORACLE SIGNER KEYPAIR (On-Chain Transactions) ---
# For local testing, use Hardhat's default pre-funded account (account index 0).
# Hardhat mnemonic: "test test test test test test test test test test test junk"
# Account 0 (oracle signer):
#   Address: 0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
#   Private Key: 0xac0974bec39a17e36ba4a6b4d238ff944bacb476cac3123b85142519f0b27c89
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb476cac3123b85142519f0b27c89

# --- ORACLE ASYMMETRIC KEYPAIR (Client-Side Session Key Encryption) ---
# The dApp encrypts each session key to VITE_ORACLE_PUBLIC_KEY.
# The oracle must hold the matching PRIVATE_KEY to decrypt it.
#
# HOW TO GENERATE:
# In your orchestration script, generate one keypair using elliptic curve (secp256k1):
#   const { createPrivateKey } = require('crypto');
#   const { sign } = require('@noble/curves/secp256k1');
#   // Use a library like ethers to generate a keypair
#   const wallet = ethers.Wallet.createRandom();
#   const publicKey = '0x04' + wallet.publicKey.substring(2).padStart(128, '0');
#   const privateKey = wallet.privateKey;
#
# Then:
#   - Inject the PUBLIC_KEY into the dApp environment (VITE_ORACLE_PUBLIC_KEY)
#   - Inject the PRIVATE_KEY into the oracle environment (below)
#
# For local testing, you can use a test keypair. Example:
#   Private: 0x1234567890abcdef...
#   Public (uncompressed, 0x04-prefixed): 0x04...
PUBLIC_KEY=0x0423d9e2cd55e1c61f8b8c6f8e2c9d5f5a5b5c5d5e5f5a5b5c5d5e5f5a5b5c5d5e5f5a5b5c5d5e5f5a5b5c5d5e5f5a5b5c5d5e5f5a5b5c

# --- CONTRACT ADDRESSES (Deploy Contracts First) ---
# After running: npm run deploy:base-localnet
# Copy the addresses from the deployment output and paste here.
#
# Example (you MUST replace with actual deployed addresses):
#   EVMAIAgent: 0x...
#   EVMAIAgentEscrow: 0x...
#   ABLE Token (if using Base sepolia): 0x...
#
AI_AGENT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
AI_AGENT_ESCROW_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
TOKEN_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# --- RPC ENDPOINT (Local Hardhat Node) ---
BASE_LOCALNET_RPC=http://127.0.0.1:8545

# --- MOCK AI & STORAGE (For Deterministic Local E2E Testing) ---
# Set both to 'true' for a fully self-contained local test:
#   - MOCK_AI: Returns deterministic mock responses instead of calling AI providers
#   - USE_MOCK_STORAGE: Stores conversation data in-memory instead of Autonomys/Irys
#
# With these flags ON:
#   ✓ No API keys needed (OpenAI, Google, ChainGPT, etc.)
#   ✓ No Autonomys or Irys credentials needed
#   ✓ No external network calls
#   ✓ Fully deterministic for testing
#
# With these flags OFF (production mode):
#   - Must configure real AI providers (Google Gemini, OpenAI, Ollama, etc.)
#   - Must configure real storage (Autonomys or Irys)
#
MOCK_AI=true
USE_MOCK_STORAGE=true

# --- DATABASE CONFIGURATION (PGLite — Embedded Local Database) ---
# PGLite is an embedded PostgreSQL that stores data locally.
# No external Postgres server needed — the data directory is relative to the oracle.
# ElizaOS (the agent framework) uses this by default.
#
# After the oracle starts, PGLite creates a local database at:
#   ./.eliza/.elizadb/
#
# For a fresh test, you can delete this directory before running.
PGLITE_DATA_DIR=./.eliza/.elizadb

# --- OPTIONAL: ELIZA/LANGUAGE MODEL CONFIGURATION ---
# If using MOCK_AI=false, you must configure at least ONE of these LLM providers.
# For local testing with MOCK_AI=true, these can be left blank.

# Google Gemini (Primary)
GOOGLE_GENERATIVE_AI_API_KEY=

# OpenAI (Fallback)
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Ollama (Local Model Server)
# If running Ollama: OLLAMA_URL=http://localhost:11434
OLLAMA_URL=

# --- ALERTING (Optional) ---
# Slack alerts for errors (optional, can be left blank for local testing)
SLACK_ACCESS_TOKEN=
SLACK_ALERT_CHANNEL=

# --- MISC CONFIGURATION ---
# Event batch size for block polling (low value for localnet)
EVENT_BATCH_SIZE=100

# Sentry error tracking (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=local

# Domain for SIWE signature validation (can be anything for local testing)
DOMAIN=localhost

# How many historical messages to include in the AI context window
AI_CONTEXT_MESSAGES_LIMIT=20
