# Network selection
NETWORK_NAME=sapphire-testnet

# Wallet for the oracle to sign transactions. This is a secret.
PRIVATE_KEY=your_private_key_here

# The public key corresponding to the PRIVATE_KEY above. Used for encryption.
# This should be the uncompressed public key (132 characters, starting with 0x04).
PUBLIC_KEY=your_rofl_worker_public_key_here

# The addresses of the contracts the oracle needs to interact with on the target network.
TOKEN_CONTRACT_ADDRESS=0xYourERC20TokenAddressHere # Optional: Used for ERC-20 payments on Base. If blank/omitted on Sapphire, native TEST/ROSE is used.
AI_AGENT_CONTRACT_ADDRESS=0xYourAIAgentAddressHere
AI_AGENT_ESCROW_CONTRACT_ADDRESS=0xYourAIAgentEscrowAddressHere

# --- Arweave/Irys Configuration ---
# The private key of the wallet used to PAY for Arweave uploads.
# This wallet must be funded with ETH on Base / Base Sepolia.
IRYS_PAYMENT_PRIVATE_KEY=your_funding_wallet_private_key_here

# The Irys network to use. "mainnet" or "devnet".
IRYS_NETWORK=devnet

# The RPC URL for the payment network. Required for devnet, recommended for mainnet.
# For testnet, use Base Sepolia. For mainnet, use Base.
IRYS_PAYMENT_RPC_URL=https://sepolia.base.org

IRYS_BALANCE_ALERT_THRESHOLD=0.02
IRYS_TOP_UP_AMOUNT=0.05 # Amount (in standard units, e.g., Base ETH) to add when balance is low

# --- Autonomys Configuration ---
AUTONOMYS_API_KEY=your_actual_api_key_from_ai3_storage
AUTONOMYS_NETWORK=mainnet  # 'testnet' (Taurus) or 'mainnet'
AUTONOMYS_UPLOAD_CREDIT_THRESHOLD=10485760
AUTONOMYS_MIN_UPLOAD_CREDITS=102400

# Domain used for SIWE authentication
DOMAIN=example.com

# The oracle will select the correct RPC endpoint from this list based on NETWORK_NAME.
BASE_MAINNET_RPC=https://mainnet.base.org
BASE_SEPOLIA_TESTNET_RPC=https://sepolia.base.org
SAPPHIRE_MAINNET_RPC=https://sapphire.oasis.io
SAPPHIRE_TESTNET_RPC=https://testnet.sapphire.oasis.io
SAPPHIRE_LOCALNET_RPC=http://localhost:8545

# API key for ChainGPT (generated on app.chaingpt.org), if used.
CHAIN_GPT_API_KEY=your_chain_gpt_key_here

# URL for a local Ollama service, if used.
OLLAMA_URL=http://ollama:11434

# 1st Party Backend URL for specific Tradable queries
TRADABLE_ASSISTANT_URL=
TRADABLE_API_ACCESS_TOKEN=

# --- Alerting Configuration ---
# For Slack alerts
SLACK_ACCESS_TOKEN=xoxb-your-bot-token-here
SLACK_ALERT_CHANNEL="#your-alerts-channel"

# For SendGrid email alerts
SEND_GRID_API_KEY=SG.your-api-key-here
SEND_GRID_ALERT_TEMPLATE_ID=d-your-template-id-here
ALERT_FROM_EMAIL=info@your-domain.com
ALERT_FROM_NAME="Oracle Alert"
ALERT_TO_EMAIL=ops-team@your-domain.com

# Number of blocks to scan per batch during catch-up.
# Set to 5-10 for Free/Public RPCs (QuickNode/Alchemy Free).
# Set to 2000 for Enterprise RPCs or Localnet.
EVENT_BATCH_SIZE=5

# --- ElizaOS / SenseAI Brain Configuration ---

# Database
PGLITE_DATA_DIR=./.eliza/.elizadb

# Primary Model Provider (Google Gemini)
GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here

# --- MODEL SELECTION ---
# Small Model: Used for chat, RAG processing, and fast responses.
# We use Gemini 3 Flash for speed.
GOOGLE_SMALL_MODEL=gemini-flash-latest
# Large Model: Used for complex reasoning and deep analysis.
# We use Gemini 3 Pro for the best intelligence.
GOOGLE_LARGE_MODEL=gemini-pro-latest
# Image Model: Used for Vision.
GOOGLE_IMAGE_MODEL=gemini-pro-latest
# Embedding Model: Used for RAG knowledge retrieval.
GOOGLE_EMBEDDING_MODEL=text-embedding-004
# Fallbacks (Good practice to set these too)
SMALL_MODEL=gemini-flash-latest
LARGE_MODEL=gemini-pro-latest
IMAGE_MODEL=gemini-pro-latest
TEXT_EMBEDDING_MODEL=text-embedding-004

# Fallback / Embedding Support
# ElizaOS often requires an OpenAI key for specific embedding tasks if Google isn't used
OPENAI_API_KEY=your_openai_key_here

# Optional Fallbacks
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# Tools & Plugins
# CoinGecko keys are used by the MCP plugin for price data
COINGECKO_API_KEY=your_coin_gecko_key_here

EVM_CHAINS=mainnet,sepolia,base,arbitrum,polygon

# Oracle Logic Settings
# How many historical messages to reconstruct from Arweave for Eliza's context window
AI_CONTEXT_MESSAGES_LIMIT=20

mcp=# Leave blank to allow MCP plugin to use runtime/character settings

# Sentry error monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
