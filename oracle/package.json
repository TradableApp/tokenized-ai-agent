{
  "name": "oracle",
  "version": "1.0.0",
  "description": "Node-based Oracle service for interacting with ROFL and off-chain inference providers like Ollama.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:localnet": "ENV_FILE=.env.oracle.localnet node src/index.js",
    "start:testnet": "ENV_FILE=.env.oracle.testnet node src/index.js",
    "start:mainnet": "ENV_FILE=.env.oracle.mainnet node src/index.js",
    "// --- BASE NETWORK SCRIPTS ---": "---",
    "start:base-localnet": "ENV_FILE=.env.oracle.base-localnet node src/index.js",
    "start:base-testnet": "ENV_FILE=.env.oracle.base-testnet node src/index.js",
    "start:base-mainnet": "ENV_FILE=.env.oracle.base-mainnet node src/index.js",
    "// --- UTILITIES ---": "---",
    "dev": "nodemon src/index.js",
    "lint": "eslint .",
    "clean": "rm -rf node_modules",
    "run-localnet": "docker run -it --platform linux/amd64 -p8545:8545 -p8546:8546 ghcr.io/oasisprotocol/sapphire-localnet -test-mnemonic",
    "run-localnet-debug": "docker run -it --platform linux/amd64 -p8545:8545 -p8546:8546 -e OASIS_NODE_LOG_LEVEL=debug -e LOG__LEVEL=debug ghcr.io/oasisprotocol/sapphire-localnet -test-mnemonic",
    "test": "DOTENV_CONFIG_PATH=./.env.oracle.example mocha -r dotenv/config --timeout 5000 --exit 'test/**/*.test.js'",
    "coverage": "nyc bun run test"
  },
  "keywords": [
    "oracle",
    "ROFL",
    "Oasis",
    "Ollama",
    "TEE",
    "AI-agent"
  ],
  "author": "Tradable",
  "license": "Apache-2.0",
  "type": "commonjs",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@autonomys/auto-drive": "^1.6.14",
    "@autonomys/auto-utils": "^1.6.14",
    "@elizaos/core": "^1.7.2",
    "@elizaos/plugin-bootstrap": "^1.7.2",
    "@elizaos/plugin-google-genai": "^1.1.0",
    "@elizaos/plugin-mcp": "^1.8.2",
    "@elizaos/plugin-sql": "^1.7.2",
    "@irys/upload": "^0.0.15",
    "@irys/upload-ethereum": "^0.0.16",
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@oasisprotocol/sapphire-ethers-v6": "^6.0.1",
    "@sentry/node": "^10.60.0",
    "@slack/web-api": "^7.17.0",
    "@tradableapp/sense-ai-shared-schema": "../packages/shared-schema",
    "async-mutex": "^0.5.0",
    "cbor": "^10.0.12",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.2",
    "ethers": "^6.17.0",
    "lru-cache": "^11.5.1",
    "p-queue": "^6.6.2",
    "siwe": "^3.0.0",
    "stopword": "^3.1.5",
    "uuid": "^11.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "chai": "^5.3.3",
    "chai-as-promised": "^8.0.2",
    "eslint": "^8.57.0",
    "mocha": "^11.7.6",
    "nodemon": "^3.1.14",
    "nyc": "^17.1.0",
    "proxyquire": "^2.1.3",
    "sinon": "^21.1.2"
  }
}
